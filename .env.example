# ─── OpenSRS Credentials ───────────────────────────────────────────────────────
# Get these from your OpenSRS reseller account at opensrs.com
# Profile → API Access → Credentials

OPENSRS_API_USERNAME=your_reseller_username
OPENSRS_PRIVATE_KEY=your_private_key_here

# "test"       → sandbox  (horizon.opensrs.net)  — safe for development
# "production" → live API (rr-n1-tor.opensrs.net) — real charges apply
OPENSRS_ENV=test

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
